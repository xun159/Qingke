<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="80dp">

        <!-- 垂直轴线 (Y 轴) -->
        <View
            android:id="@+id/axis_y"
            android:layout_width="2dp"
            android:layout_height="0dp"
            android:background="#2C3E50"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 水平轴线 (X 轴) -->
        <View
            android:id="@+id/axis_x"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:background="#2C3E50"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 坐标原点 (中心点) -->
        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="#2C3E50"
            android:layout_margin="-5dp"
            app:layout_constraintTop_toTopOf="@id/axis_x"
            app:layout_constraintBottom_toBottomOf="@id/axis_x"
            app:layout_constraintStart_toStartOf="@id/axis_y"
            app:layout_constraintEnd_toEndOf="@id/axis_y" />

        <!-- 坐标轴标签 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="重要"
            android:textSize="12sp"
            android:textColor="#2C3E50"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="@id/axis_y"
            app:layout_constraintEnd_toEndOf="@id/axis_y" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="紧急"
            android:textSize="12sp"
            android:textColor="#2C3E50"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toTopOf="@id/axis_x"
            app:layout_constraintBottom_toBottomOf="@id/axis_x"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 第一象限 (右上：重要且紧急) -->
        <LinearLayout
            android:id="@+id/q1_area"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="30dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/axis_x"
            app:layout_constraintStart_toEndOf="@id/axis_y"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="重要\n紧急" android:textSize="11sp" android:textColor="#E74C3C"
                android:textStyle="bold" android:layout_marginBottom="8dp" />

            <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:scrollbars="none">
                <LinearLayout android:id="@+id/q1_list" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="vertical" />
            </ScrollView>
        </LinearLayout>

        <!-- 第二象限 (左上：重要不紧急) -->
        <LinearLayout
            android:id="@+id/q2_area"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingTop="30dp"
            android:paddingEnd="20dp"
            android:paddingBottom="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/axis_x"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/axis_y">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="重要\n不紧急" android:textSize="11sp" android:textColor="#27AE60"
                android:textStyle="bold" android:layout_marginBottom="8dp" android:layout_gravity="end" />

            <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:scrollbars="none">
                <LinearLayout android:id="@+id/q2_list" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="vertical" />
            </ScrollView>
        </LinearLayout>

        <!-- 第四象限 (左下：不重要不紧急) - 原第三象限位置 -->
        <LinearLayout
            android:id="@+id/q4_area"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingTop="12dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp"
            app:layout_constraintTop_toBottomOf="@id/axis_x"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/axis_y">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="不重要\n不紧急" android:textSize="11sp" android:textColor="#3498DB"
                android:textStyle="bold" android:layout_marginBottom="8dp" android:layout_gravity="end" />

            <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:scrollbars="none">
                <LinearLayout android:id="@+id/q4_list" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="vertical" />
            </ScrollView>
        </LinearLayout>

        <!-- 第三象限 (右下：紧急不重要) - 原第四象限位置 -->
        <LinearLayout
            android:id="@+id/q3_area"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="20dp"
            app:layout_constraintTop_toBottomOf="@id/axis_x"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/axis_y"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="紧急\n不重要" android:textSize="11sp" android:textColor="#F39C12"
                android:textStyle="bold" android:layout_marginBottom="8dp" />

            <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:scrollbars="none">
                <LinearLayout android:id="@+id/q3_list" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="vertical" />
            </ScrollView>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#2C3E50"
        app:tint="#FFFFFF"
        app:elevation="8dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>